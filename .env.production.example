# === Production Environment ===
# Copy to .env.production on the VPS and fill in values.
# DATABASE_URL is set in docker-compose.yml — do NOT add it here.

# NextAuth v5
AUTH_SECRET=<run: openssl rand -base64 32>
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_TRUST_HOST=true

# Mapbox
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
MAPBOX_ACCESS_TOKEN=

# App
NEXTAUTH_URL=https://skipthemid.com
NODE_ENV=production
