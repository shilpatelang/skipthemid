generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id        String   @id // Mapbox feature ID
  name      String
  longitude Float
  latitude  Float
  address   String?
  category  String? // "restaurant", "bar", etc.
  syncedAt  DateTime @default(now())
  dishes    Dish[]
}

// --- NextAuth models ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  dishes        Dish[]
  votes         Vote[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- App models ---

model Dish {
  id           String   @id @default(cuid())
  name         String
  tag          String // "BEST" or "MID" (SQLite has no enums)
  price        Float?
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  votes        Vote[]
  createdAt    DateTime @default(now())
}

model Vote {
  id        String   @id @default(cuid())
  value     Int // +1 or -1
  dishId    String
  dish      Dish     @relation(fields: [dishId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([dishId, userId])
}
