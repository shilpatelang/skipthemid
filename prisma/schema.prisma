generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Kept from Phase 0 — already seeded from Mapbox.
// Will be linked to dishes via junction table in Phase 2.
model Restaurant {
  id        String   @id // Mapbox feature ID
  name      String
  longitude Float
  latitude  Float
  address   String?
  category  String? // venue type: "restaurant", "bar", etc.
  syncedAt  DateTime @default(now())
}

// --- NextAuth models ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // hashed; null for OAuth-only users
  accounts      Account[]
  sessions      Session[]
  ratings       Rating[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- App models ---

model Dish {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  ingredients Json?    // [{name, amount, unit}]
  steps       Json?    // ["step 1", "step 2", ...]
  prepTime    Int?     // minutes
  cookTime    Int?     // minutes
  servings    Int?
  origin      String   // e.g. "Kerala, India" — human-readable, used for display
  cuisine     String   // e.g. "South Indian"
  category    String   // e.g. "Street Food", "Curry", "Dessert" — granular display tag
  // --- Filter taxonomy (slug-style values for URL safety) ---
  // Defaults are placeholders to satisfy SQLite migrations on existing rows;
  // seed.ts populates real values via TAXONOMY map. Safe to remove defaults
  // once schema stabilizes.
  continent   String   @default("") // africa | asia | europe | north-america | south-america | oceania
  country     String   @default("") // e.g. "india", "peru", "indonesia"
  region      String?  // optional state/province slug, e.g. "kerala", "bihar"
  course      String   @default("") // street-food | main | dessert | appetizer | side | snack
  dietType    String   @default("") // vegan | vegetarian | non-vegetarian | contains-egg
  imageUrl    String?
  imageCredit     String?  // e.g. "Photo: John Doe / Unsplash"
  imageLicenseUrl String?  // e.g. "https://creativecommons.org/licenses/by-sa/4.0/"
  latitude    Float    // Origin location for map pin
  longitude   Float    // Origin location for map pin
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ratings     Rating[]
  places      Place[]
}

model Place {
  id        String  @id @default(cuid())
  name      String
  address   String?
  city      String
  country   String
  latitude  Float
  longitude Float
  dishId    String
  dish      Dish    @relation(fields: [dishId], references: [id], onDelete: Cascade)
}

model Rating {
  id        String   @id @default(cuid())
  value     Float    // 0.5–5 stars (half-star increments)
  dishId    String
  dish      Dish     @relation(fields: [dishId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([dishId, userId])
}
