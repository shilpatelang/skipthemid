generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Kept from Phase 0 — already seeded from Mapbox.
// Will be linked to dishes via junction table in Phase 2.
model Restaurant {
  id        String   @id // Mapbox feature ID
  name      String
  longitude Float
  latitude  Float
  address   String?
  category  String? // venue type: "restaurant", "bar", etc.
  syncedAt  DateTime @default(now())
}

// --- NextAuth models ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  ratings       Rating[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- App models ---

model Dish {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  recipe      String?
  origin      String   // e.g. "Kerala, India"
  cuisine     String   // e.g. "South Indian"
  category    String   // e.g. "Street Food", "Curry", "Dessert"
  imageUrl    String?
  latitude    Float    // Origin location for map pin
  longitude   Float    // Origin location for map pin
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ratings     Rating[]
}

model Rating {
  id        String   @id @default(cuid())
  value     Int      // 1–5 stars
  dishId    String
  dish      Dish     @relation(fields: [dishId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([dishId, userId])
}
